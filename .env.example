## Railway / production env (root)
# Le serveur Node est dans /backend. Railway injecte PORT automatiquement.
# Vous pouvez aussi définir ces variables dans Railway → Variables.

# URL frontend (optionnel, utile en local / reverse proxy)
FRONTEND_ORIGIN=http://localhost:5173

# Allowlist CORS (séparée par des virgules). Si vide, accepte Origin *.railway.app et *.qhsecontrol.com + same-origin.
# CORS_ALLOWED_ORIGINS=https://monapp.up.railway.app,https://qhsecontrol.com
CORS_ALLOWED_ORIGINS=

# Clé publique d’accès API (utilisée par le frontend via /api/public/config)
PUBLIC_API_KEY=dev-public-key-change-me

# Administration (header x-admin-secret sur /api/admin/*) — long random string en prod
ADMIN_SECRET=

# Supabase (optionnel)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# Réception alertes lead DUERP (backend). Défaut conseillé : devis@qhsecontrol.com
LEADS_TO_EMAIL=devis@qhsecontrol.com
LEAD_RECEIVER_EMAIL=
MAIL_FROM=contact@qhsecontrol.com
MAIL_REPLY_TO=devis@qhsecontrol.com

# OpenAI — suggestions de risques (optionnel, backend)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

