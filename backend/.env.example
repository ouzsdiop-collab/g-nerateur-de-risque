PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
# Optionnel : allowlist CORS (séparée par des virgules). Si vide, accepte Origin *.railway.app et *.qhsecontrol.com + same-origin.
# Exemple : CORS_ALLOWED_ORIGINS=https://monapp.up.railway.app,https://qhsecontrol.com
CORS_ALLOWED_ORIGINS=
PUBLIC_API_KEY=dev-public-key-change-me
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
LEAD_RECEIVER_EMAIL=qhsecontrol@outlook.com

# Suggestions de risques (OpenAI) — optionnel
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
