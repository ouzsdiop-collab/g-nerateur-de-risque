PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
# Optionnel : allowlist CORS (séparée par des virgules). Si vide, accepte Origin *.railway.app et *.qhsecontrol.com + same-origin.
# Exemple : CORS_ALLOWED_ORIGINS=https://monapp.up.railway.app,https://qhsecontrol.com
CORS_ALLOWED_ORIGINS=
PUBLIC_API_KEY=dev-public-key-change-me
# Clé longue pour /api/admin/* et page /admin-qhse-control (header x-admin-secret). Ne jamais committer la vraie valeur.
ADMIN_SECRET=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# Réception des leads DUERP (prioritaire). Sinon secours : LEAD_RECEIVER_EMAIL.
LEADS_TO_EMAIL=devis@qhsecontrol.com
# Alias historique si LEADS_TO_EMAIL absent
LEAD_RECEIVER_EMAIL=
# Expéditeur affiché (souvent identique au compte SMTP Microsoft 365)
MAIL_FROM=contact@qhsecontrol.com
# Si le lead n'a pas laissé d'email, en-tête Reply-To optionnel
MAIL_REPLY_TO=devis@qhsecontrol.com

# Suggestions de risques (OpenAI) — optionnel
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
