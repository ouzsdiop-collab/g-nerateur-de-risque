# Copier vers .env et renseigner les valeurs.

OPENAI_API_KEY=
PORT=3008

# ── Sécurité admin ──
# Token secret pour accéder aux routes /api/leads et /api/leads/export.csv
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# ── Emails transactionnels (même expéditeur pour notification interne + prospect) ──
# Sans SMTP complet : les leads sont tout de même enregistrés dans leads.json.
NOTIFY_EMAIL_TO=qhsecontrol@outlook.com

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=qhsecontrol@outlook.com
SMTP_PASS=
SMTP_FROM=qhsecontrol@outlook.com
